{
  "name": "WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "public_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://ws.okx.com:8443/ws/v5/public",
      "description": "WS end-point (URI)"
    },
    {
      "name": "private_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://ws.okx.com:8443/ws/v5/private",
      "description": "WS end-point (URI)"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "max_subscriptions_per_stream",
      "type": "uint32_t",
      "required": true,
      "default": 32,
      "description": "max symbols per connection (count)"
    },
    {
      "name": "books_depth",
      "type": "uint16_t",
      "required": true,
      "default": 400,
      "description": "defines what 'books' channel to subscribe to (some require authentication)"
    },
    {
      "name": "books_use_public",
      "type": "bool",
      "default": false,
      "description": "opt-out from the real-time feeds requiring VIP membership"
    },
    {
      "name": "disconnect_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "10s",
      "description": "disconnect timeout"
    }
  ]
}
