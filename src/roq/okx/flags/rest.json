{
  "name": "REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "https://www.okx.com",
      "description": "Exchange end-point"
    },
    {
      "name": "host",
      "type": "std/string",
      "description": "Host (when URI is an IP address)"
    },
    {
      "name": "proxy",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "description": "Proxy end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "10s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std/string",
      "validator": "roq::flags::validators::Path",
      "default": "/api/v5/public/time",
      "description": "Ping path"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Request timeout"
    }
  ]
}
