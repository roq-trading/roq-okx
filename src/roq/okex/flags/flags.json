{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "config file (path)"
    },
    {
      "name": "secrets_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "secrets file (path, optional)"
    },
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty<std::string>",
      "default": "kucoin",
      "description": "exchange identifier (string)"
    },
    {
      "name": "rest_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "https://openapi-sandbox.kucoin.com",
      "description": "REST end-point (URI)"
    },
    {
      "name": "rest_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "rest_ping_path",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "default": "/api/v1/status",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "rest_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "30s",
      "description": "request: timeout"
    },
    {
      "name": "rest_download_orders_page_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 500,
      "description": "page size used when downloading orders"
    },
    {
      "name": "rest_download_orders_begin",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "24h",
      "description": "download orders since (now - begin)"
    },
    {
      "name": "rest_download_only_active_orders",
      "type": "bool",
      "default": false,
      "description": "download only active orders?"
    },
    {
      "name": "rest_download_fills_page_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 500,
      "description": "page size used when downloading fills"
    },
    {
      "name": "rest_download_fills_begin",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "24h",
      "description": "download fills since (now - begin)"
    },
    {
      "name": "rest_token_refresh_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "8h",
      "description": "token refresh frequency"
    },
    {
      "name": "ws_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "ws_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "15s",
      "description": "request: timeout"
    },
    {
      "name": "ws_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 100,
      "description": "max symbols per connection (count)"
    },
    {
      "name": "ws_mbp_request_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "500ms",
      "description": "request delay"
    },
    {
      "name": "ws_mbp_request_max_retries",
      "type": "uint32_t",
      "default": 3,
      "description": "request max retries"
    },
    {
      "name": "request_limit",
      "type": "uint32_t",
      "default": "80",
      "description": "request limit per interval"
    },
    {
      "name": "request_limit_interval",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "10s",
      "description": "request limit monitor interval"
    },
    {
      "name": "self_trade_prevention",
      "type": "std::string",
      "default": "CN",
      "description": "self-trade prevention: CN, CO, CB, DC"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1048576,
      "description": "encode buffer size"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    },
    {
      "name": "mbp_allow_price_inversion",
      "type": "bool",
      "default": false,
      "description": "allow price inversion?"
    }
  ]
}
